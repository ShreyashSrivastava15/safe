generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password_hash String
  full_name     String?
  avatar_url    String?
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  logs          AnalysisLog[]
  googleToken   GoogleToken?

  @@map("users")
}

model AnalysisLog {
  id               String    @id @default(uuid())
  user_id          String?
  user             User?     @relation(fields: [user_id], references: [id])
  fraud_type       String?
  created_at       DateTime? @default(now())
  message          String?
  url              String?
  transaction_json Json?     @default("{}")
  scores_json      Json?     @default("{}")
  signals          Json?     @default("[]")
  findings_json    Json?     @default("[]")
  final_score      Float?
  risk_level       String?
  verdict          String?
  explanation      String?
  confidence       Float?
  recommendation   String?

  @@map("analysis_logs")
}

model GoogleToken {
  id            String   @id @default(uuid())
  user_id       String   @unique
  user          User     @relation(fields: [user_id], references: [id])
  access_token  String
  refresh_token String?
  expiry_date   BigInt?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("google_tokens")
}

model TrustedSource {
  id          String   @id @default(uuid())
  domain      String   @unique
  name        String
  category    String?  // e.g., 'Financial', 'Gov', 'Tech'
  trust_score Float    @default(1.0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("trusted_sources")
}
