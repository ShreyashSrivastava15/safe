{
    "manifest_version": 3,
    "name": "S.A.F.E. Guardian",
    "version": "1.1",
    "description": "Automatic AI-powered fraud detection for your emails.",
    "permissions": [
        "storage",
        "notifications"
    ],
    "host_permissions": [
        "https://mail.google.com/*",
        "https://outlook.live.com/*",
        "http://localhost:3000/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://mail.google.com/*",
                "https://outlook.live.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ]
}